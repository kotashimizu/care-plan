# Vertex AI Configuration (Service Account)
# サービスアカウントキーJSONをBase64エンコードした値を設定
# 生成方法: base64 -i your-service-account-key.json | tr -d '\n'
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=asia-northeast1
GOOGLE_SERVICE_ACCOUNT_KEY=your_base64_encoded_service_account_key
# GEMINI_MODEL=gemini-2.5-flash

# API Access Password (optional - leave empty for development)
# API_ACCESS_PASSWORD=your_secure_password_here

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
